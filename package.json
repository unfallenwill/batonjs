{
  "name": "agentflow",
  "version": "1.0.0",
  "description": "A lightweight workflow engine that orchestrates AI agents using the CodeBuddy Agent SDK",
  "keywords": [
    "workflow",
    "agent",
    "orchestration",
    "codebuddy",
    "ai",
    "automation"
  ],
  "author": "caosen",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unfallenwill/agentflow.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "agentflow": "./dist/cli.mjs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "check": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@tencent-ai/agent-sdk": "^0.3.162",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
