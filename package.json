{
  "name": "batonjs",
  "version": "0.0.1",
  "description": "A lightweight workflow engine that orchestrates AI agents via pluggable SDK backends",
  "keywords": [
    "workflow",
    "agent",
    "orchestration",
    "anthropic",
    "claude",
    "codebuddy",
    "ai",
    "automation",
    "batonjs"
  ],
  "author": "caosen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unfallenwill/batonjs.git"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "batonjs": "./dist/cli.mjs"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "lint:deps": "depcruise src",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run lint:deps",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.160",
    "@tencent-ai/agent-sdk": "^0.3.162",
    "ajv": "^8.20.0",
    "cac": "^7.0.0",
    "json5": "^2.2.3",
    "sucrase": "^3.35.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.8",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
